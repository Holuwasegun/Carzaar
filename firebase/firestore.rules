rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Replace with your real Firebase Auth UID for your admin account
    function isAdmin() {
      return request.auth != null && request.auth.uid == "YOUR_ADMIN_UID_HERE";
    }

    match /listings/{listingId} {
      allow read: if true; // Public can see cars
      allow write: if isAdmin(); // Only you can add/edit/delete
    }
  }
}
