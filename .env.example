# Database
DATABASE_URL="postgresql://user:password@localhost:5432/carzaar"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Default Admin Credentials (used during prisma db seed)
ADMIN_EMAIL="admin@carzaar.com"
ADMIN_PASSWORD="YourSecurePassword123!"
ADMIN_WHATSAPP="2349158461502"

# Cloudflare R2 / AWS S3 Image Storage
R2_ACCOUNT_ID="your-cloudflare-account-id-or-aws-region"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="carzaar-images"
R2_PUBLIC_URL="https://pub-your-bucket-id.r2.dev"
